# ============================================================
# SightLine Backend - Environment Variables
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# === [人工] GCP 基础 — 你需要手动获取 ===
GOOGLE_CLOUD_PROJECT=                          # GCP 项目 ID，如 sightline-hackathon(https://console.cloud.google.com/billing/017561-854919-D6B87F?project=sightline-hackathon&cloudshell=true&chat=true)
GOOGLE_CLOUD_LOCATION=us-central1              # 区域（保持默认即可）
GOOGLE_GENAI_USE_VERTEXAI=TRUE                 # 本地开发: TRUE (Vertex AI + ADC 认证)
                                               # Cloud Run: FALSE (Developer API + GOOGLE_API_KEY)
                                               # 区别: TRUE 时走 Vertex AI 端点，需要 ADC/SA；
                                               #        FALSE 时走 generativelanguage.googleapis.com，只需 API key

# === [人工] Gemini API — 从 AI Studio 获取 ===
GOOGLE_API_KEY=                                # https://aistudio.google.com/apikey 生成

# === [人工] Google Maps — 从 Cloud Console 获取 ===
GOOGLE_MAPS_API_KEY=                           # Console → APIs & Services → Credentials

# === [自动] Gemini 模型 ID — 无需修改 ===
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI_VISION_MODEL=gemini-3.1-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# === [Optional] Session persistence — only needed for VertexAiSessionService ===
AGENT_ENGINE_ID=                               # SessionService persistence only; does not affect Memory (Memory uses Firestore directly)

# === [自动] Cloud Run 部署参数 — 无需修改 ===
MIN_INSTANCE_COUNT=1                           # 消除冷启动
TIMEOUT=3600                                   # WebSocket 长连接（秒）
MEMORY=2Gi                                     # 容器内存
CPU=2                                          # vCPU 数

# === [自动] InsightFace 人脸识别 — 无需修改 ===
FACE_MATCH_THRESHOLD=0.4                       # 余弦相似度匹配阈值
MAX_FACES_IN_LIBRARY=100                       # 内存加载上限
