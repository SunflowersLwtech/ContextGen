rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profiles ──────────────────────────────────────────────
    // Only the user themselves can read/write their profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Face Library: user can read; registered_by helper can write
      match /face_library/{faceId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null;
      }

      // Session metadata: only the user can read/write
      match /sessions_meta/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Memories sub-collection: only the user can read/write their memories
      match /memories/{memoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Memories (fallback self-managed collection) ────────────────
    // Only the owning user can access their memories.
    match /memories/{memoryId} {
      allow read, write: if request.auth != null
        && request.auth.uid == resource.data.user_id;
      // Allow create when user_id in the incoming data matches auth uid
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.user_id;
    }

    // ── Deny all other access by default ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
